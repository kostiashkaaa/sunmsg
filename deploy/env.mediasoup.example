# mediasoup server environment - copy to /srv/sunmessenger/shared/.env.mediasoup on the server

MEDIASOUP_API_PORT=3000
MEDIASOUP_API_SECRET=CHANGE_ME_STRONG_SECRET_HERE
MEDIASOUP_REQUIRE_E2EE=1

# Public IP of the server - clients will connect to this address for RTP
MEDIASOUP_ANNOUNCED_IP=YOUR_PUBLIC_IP

# Listen on all interfaces internally
MEDIASOUP_LISTEN_IP=0.0.0.0

# RTP port range (must be open in firewall, UDP)
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999
