[Unit]
Description=SUN Messenger production config check
After=network.target

[Service]
Type=oneshot
User=sunmessenger
Group=sunmessenger
WorkingDirectory=/srv/sunmessenger/current
EnvironmentFile=/srv/sunmessenger/shared/.env
ExecStart=/srv/sunmessenger/venv/bin/python manage.py production-config-check --env production

