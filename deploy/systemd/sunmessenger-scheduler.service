[Unit]
Description=SUN Messenger scheduler
After=network.target redis.service
Requires=redis.service

[Service]
Type=simple
User=sunmessenger
Group=sunmessenger
WorkingDirectory=/srv/sunmessenger/current
EnvironmentFile=/srv/sunmessenger/shared/.env
ExecStart=/srv/sunmessenger/current/.venv/bin/python manage.py scheduler
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
