APP_ENV=production
APP_DEBUG=0

SECRET_KEY=replace-with-64-bytes-random-secret

DATABASE_URL=postgresql://sunmessenger:replace-me@127.0.0.1:5432/sunmessenger
TEST_DATABASE_URL=postgresql://sunmessenger:replace-me@127.0.0.1:5432/sunmessenger_test
DATABASE_BACKUP_DIR=/srv/sunmessenger/shared/backups

REDIS_URL=redis://127.0.0.1:6379/0
RATELIMIT_STORAGE_URI=redis://127.0.0.1:6379/1
SOCKETIO_MESSAGE_QUEUE=redis://127.0.0.1:6379/2
RATELIMIT_DEFAULT=300 per minute
RATELIMIT_APPLICATION=5000 per minute

SOCKETIO_ASYNC_MODE=threading
SOCKETIO_CORS_ORIGINS=https://sunmessenger.ru,https://www.sunmessenger.ru
SOCKETIO_CLIENT_TRANSPORTS=polling,websocket
SOCKETIO_CLIENT_UPGRADE=0
SOCKETIO_PING_TIMEOUT=30
SOCKETIO_PING_INTERVAL=15
SOCKETIO_MAX_HTTP_BUFFER_SIZE_MB=16
SOCKET_CONNECT_IP_LIMIT=180
SOCKET_CONNECT_IP_WINDOW_SECONDS=60
SOCKET_MAX_CONNECTIONS_PER_USER=12

PERMANENT_SESSION_LIFETIME_DAYS=30
MAX_CONTENT_LENGTH_MB=100
CHAT_MEDIA_CACHE_MAX_AGE_SECONDS=3600
CHAT_MEDIA_AV_SCAN_ENABLED=1
CHAT_MEDIA_AV_FAIL_CLOSED=1
CHAT_MEDIA_AV_TIMEOUT_SECONDS=20
CHAT_MEDIA_AV_COMMAND=clamdscan --fdpass --no-summary {path} || clamscan --no-summary --infected --stdout {path}
WEB_PUSH_ENABLED=1
WEB_PUSH_VAPID_PUBLIC_KEY=replace-with-vapid-public-key
WEB_PUSH_VAPID_PRIVATE_KEY=replace-with-vapid-private-key
WEB_PUSH_VAPID_SUBJECT=mailto:ops@sunmessenger.ru
MODERATOR_USER_IDS=
MODERATION_BLOCKED_PUBLIC_DOMAINS=
MODERATION_HIGH_RISK_IP_CIDRS=
MODERATION_AUTO_ACTION_THRESHOLD=0.85
MODERATION_AUTO_ACTION_TYPE=mute_temp
MODERATION_AUTO_ACTION_TTL_SECONDS=3600
MODERATION_REPORT_RATE_WINDOW_SECONDS=3600
MODERATION_REPEAT_WINDOW_DAYS=90
MODERATION_REPORT_RATE_THRESHOLD=5
MODERATION_REPORT_ASYNC_ENABLED=1
MODERATION_JOB_MAX_ATTEMPTS=5
MODERATION_JOB_RETRY_DELAY_SECONDS=30
MODERATION_WORKER_ID=moderation-worker-1
MODERATION_SLA_PRIORITY_1_SECONDS=900
MODERATION_SLA_PRIORITY_2_SECONDS=3600
MODERATION_SLA_PRIORITY_3_SECONDS=14400
MODERATION_SLA_PRIORITY_4_SECONDS=43200
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=1

SCHEDULER_ENABLED=1
START_SCHEDULER_IN_WEB=0
RUN_MIGRATIONS_ON_STARTUP=0
FORCE_HTTPS=1

HOST=127.0.0.1
PORT=5000
TLS_PORT=443
ALLOW_UNSAFE_WERKZEUG=0
ALLOW_EMBEDDED_WEB_SERVER=0
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
PROXY_FIX_X_PORT=1
PROXY_FIX_X_PREFIX=0

SCRIPT_SRC_HOSTS=
STYLE_SRC_HOSTS=
FONT_SRC_HOSTS=
IMG_SRC_HOSTS=
MEDIA_SRC_HOSTS=
CONNECT_SRC_HOSTS=
CSP_STYLE_UNSAFE_INLINE=1
