# Development-only template. Do not use these defaults in production.
APP_ENV=development
APP_DEBUG=0

SECRET_KEY=change-me

DATABASE_BACKEND=postgres
DATABASE_URL=postgresql://postgres:change-me@127.0.0.1:5432/sunmessenger
TEST_DATABASE_URL=postgresql://postgres:change-me@127.0.0.1:5432/sunmessenger_test
POSTGRES_MAINTENANCE_URL=postgresql://postgres:change-me@127.0.0.1:5432/postgres
DATABASE_BACKUP_DIR=
# Optional PostgreSQL schema override. Mostly useful for isolated tests/staging.
DATABASE_SCHEMA=
DB_POOL_MAX_SIZE=12
DB_POOL_ACQUIRE_TIMEOUT_SECONDS=5

REDIS_URL=
RATELIMIT_STORAGE_URI=
RATELIMIT_DEFAULT=300 per minute
RATELIMIT_APPLICATION=5000 per minute
SOCKETIO_MESSAGE_QUEUE=

SOCKETIO_ASYNC_MODE=threading
SOCKETIO_CORS_ORIGINS=*
SOCKETIO_CLIENT_TRANSPORTS=websocket,polling
SOCKETIO_CLIENT_UPGRADE=1
SOCKETIO_PING_TIMEOUT=30
SOCKETIO_PING_INTERVAL=15
SOCKETIO_MAX_HTTP_BUFFER_SIZE_MB=16
SOCKET_CONNECT_IP_LIMIT=180
SOCKET_CONNECT_IP_WINDOW_SECONDS=60
SOCKET_MAX_CONNECTIONS_PER_USER=12
SOCKET_RATE_REDIS_URL=
SOCKET_RATE_GLOBAL_EVENT_LIMIT=5000
SOCKET_RATE_GLOBAL_EVENT_WINDOW_SECONDS=60
TRUST_RAMP_NEW_ACCOUNT_SECONDS=86400
TRUST_RAMP_SIGNAL_WINDOW_SECONDS=86400
TRUST_RAMP_MIN_CONFIRMED_CONTACTS=3
TRUST_RAMP_MIN_INBOUND_REPLIERS=2
TRUST_RAMP_CONTACT_REQUEST_LIMIT=5 per minute
TRUST_RAMP_PUBLIC_START_LIMIT=5 per minute
TRUST_RAMP_GROUP_CREATE_LIMIT=5 per hour
TRUST_RAMP_GROUP_MUTATION_LIMIT=10 per hour
TRUST_RAMP_AVATAR_UPLOAD_LIMIT=3 per hour
TRUST_RAMP_MEDIA_UPLOAD_LIMIT=20 per hour
SOCKET_SEND_BURST_LIMIT=8
SOCKET_SEND_BURST_WINDOW_SECONDS=10
SOCKET_SEND_NEW_ACCOUNT_BURST_LIMIT=3
SOCKET_SEND_CHAT_SENDER_LIMIT=20
SOCKET_SEND_CHAT_SENDER_WINDOW_SECONDS=60
SOCKET_SEND_NEW_ACCOUNT_CHAT_SENDER_LIMIT=8
SOCKET_SEND_UNKNOWN_RECIPIENT_LIMIT=3
SOCKET_SEND_UNKNOWN_RECIPIENT_WINDOW_SECONDS=86400
SOCKET_SEND_MEDIA_LIMIT=30
SOCKET_SEND_MEDIA_WINDOW_SECONDS=3600
SOCKET_SEND_NEW_ACCOUNT_MEDIA_LIMIT=6
ABUSE_AUTO_MUTE_ENABLED=1
ABUSE_AUTO_MUTE_WINDOW_SECONDS=3600
ABUSE_AUTO_MUTE_TTL_SECONDS=3600
ABUSE_AUTO_MUTE_REPORTS_THRESHOLD=3
ABUSE_AUTO_MUTE_BLOCKS_THRESHOLD=5
ABUSE_AUTO_MUTE_SENDS_THRESHOLD=120

PERMANENT_SESSION_LIFETIME_DAYS=30
MAX_CONTENT_LENGTH_MB=100
CHAT_MEDIA_CACHE_MAX_AGE_SECONDS=3600
CHAT_MEDIA_AV_SCAN_ENABLED=0
CHAT_MEDIA_AV_FAIL_CLOSED=0
CHAT_MEDIA_AV_TIMEOUT_SECONDS=20
CHAT_MEDIA_AV_COMMAND=clamdscan --fdpass --no-summary {path} || clamscan --no-summary --infected --stdout {path}
CHAT_MEDIA_AV_SCAN_EXTENSIONS=zip,rar,7z
WEB_PUSH_ENABLED=0
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:noreply@sunmessenger.local
MODERATOR_USER_IDS=
MODERATION_BLOCKED_PUBLIC_DOMAINS=

# Calls (P2P WebRTC / coturn TURN server)
# SECURITY: TURN credentials issued by /call/ice-config are valid bearer tokens
# for the relay. Any logged-in user can extract them and route arbitrary traffic
# through coturn until they expire (amplification / open-relay abuse). Mitigate:
#   - keep TURN_CREDENTIAL_TTL_SECONDS short (300-600 s recommended, not 3600);
#   - set per-credential quotas in turnserver.conf:
#       user-quota=12        # max simultaneous allocations per credential
#       total-quota=1200     # server-wide allocation cap
#       max-bps=2000000      # per-session bandwidth cap (~2 Mbit/s)
#   - keep the TURN listener firewalled to the RTP port range only.
TURN_SECRET=CHANGE_ME_STRONG_TURN_SECRET_HERE
# Legacy single TURN URL fallback. Prefer TURN_SERVER_URLS or TURN_SERVER_POOL.
TURN_SERVER_URL=
TURN_SERVER_URLS=turn:your-server.example.com:3478?transport=udp,turn:your-server.example.com:3478?transport=tcp,turns:your-server.example.com:5349?transport=tcp
# Optional structured pool. If set, /call/ice-config selects enabled relays with
# health_score > 0 and ignores legacy TURN_SERVER_URLS until the pool is removed.
# Keep this JSON on one line in .env files.
TURN_SERVER_POOL='[{"id":"primary","urls":["turn:turn1.example.com:3478?transport=udp","turn:turn1.example.com:3478?transport=tcp","turns:turn1.example.com:5349?transport=tcp"],"health_score":100,"enabled":true},{"id":"backup","urls":["turn:turn2.example.com:3478?transport=udp","turns:turn2.example.com:5349?transport=tcp"],"health_score":80,"enabled":true}]'
TURN_SERVER_POOL_LIMIT=2
# Shorter TTL limits the blast radius of leaked credentials. The client refetches
# automatically; 300-600 s is a good balance. 3600 s is the upper bound.
TURN_CREDENTIAL_TTL_SECONDS=600
# Use relay only as an incident-mode switch when direct/STUN paths are unstable.
# Valid values: all, relay.
CALL_ICE_TRANSPORT_POLICY=all
CALL_DISCONNECT_GRACE_SECONDS=45
MODERATION_HIGH_RISK_IP_CIDRS=
MODERATION_AUTO_ACTION_THRESHOLD=0.85
MODERATION_AUTO_ACTION_TYPE=mute_temp
MODERATION_AUTO_ACTION_TTL_SECONDS=3600
MODERATION_REPORT_RATE_WINDOW_SECONDS=3600
MODERATION_REPEAT_WINDOW_DAYS=90
MODERATION_REPORT_RATE_THRESHOLD=5
MODERATION_REPORT_ASYNC_ENABLED=1
MODERATION_JOB_MAX_ATTEMPTS=5
MODERATION_JOB_RETRY_DELAY_SECONDS=30
MODERATION_WORKER_ID=moderation-worker
MODERATION_SLA_PRIORITY_1_SECONDS=900
MODERATION_SLA_PRIORITY_2_SECONDS=3600
MODERATION_SLA_PRIORITY_3_SECONDS=14400
MODERATION_SLA_PRIORITY_4_SECONDS=43200
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=0

SCHEDULER_ENABLED=1
START_SCHEDULER_IN_WEB=0
RUN_MIGRATIONS_ON_STARTUP=1
FORCE_HTTPS=0
WEBAUTHN_RP_ID=sun.localhost
WEBAUTHN_ORIGIN=
WEBAUTHN_RP_NAME=SUN Messenger

HOST=127.0.0.1
PORT=5000
TLS_PORT=443
TLS_CERT_PATH=/etc/letsencrypt/live/sunmessenger.ru/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/sunmessenger.ru/privkey.pem
ALLOW_UNSAFE_WERKZEUG=1
ALLOW_EMBEDDED_WEB_SERVER=1
PROXY_FIX_X_FOR=0
PROXY_FIX_X_PROTO=0
PROXY_FIX_X_HOST=0
PROXY_FIX_X_PORT=0
PROXY_FIX_X_PREFIX=0

SCRIPT_SRC_HOSTS=
STYLE_SRC_HOSTS=
FONT_SRC_HOSTS=
IMG_SRC_HOSTS=
MEDIA_SRC_HOSTS=
CONNECT_SRC_HOSTS=
CSP_STYLE_UNSAFE_INLINE=1

# Spotify Integration (optional)
# Register your app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5000/spotify/callback
SPOTIFY_POLLING_INTERVAL_SECONDS=5

# Optional local diagnostics / test runner knobs.
SQL_PROFILE_ENABLED=0
SQL_PROFILE_SLOW_MS=25
SQL_PROFILE_LOG_PATH=
PLAYWRIGHT_BASE_URL=http://127.0.0.1:5000
PLAYWRIGHT_HEADLESS=1
PLAYWRIGHT_SLOW_MO=0
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_UPDATE_BASELINE=0
TEST_SCHEMA_SALT=
